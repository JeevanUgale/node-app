pipeline {
    
    agent any
    
    tools {
        nodejs "node"
    }
    
    environment {
        IMAGE_NAME = "jeevanugale/nodejs-app"
        TAG = "${BUILD_NUMBER}"
    }
    
    stages {

        stage ('AWS configure') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws configure set aws_access_key_id $AWS_ACCESS_KEY_ID
                    aws configure set aws_secret_access_key $AWS_SECRET_ACCESS_KEY
                    aws configure set default.region ap-south-1
                    '''
                }
            }
        }
        stage ('Generate SSH Key for EC2') {
            steps {
                sh '''
                cd Iac
                ssh-keygen -t rsa -b 4096 -f jenkins_key -N ""
                '''
            }
        }

        stage ('Terraform Init and Validate') {
            steps {
                sh '''
                cd Iac
                terraform init
                terraform validate
                '''
            }
        }

        stage ('Terraform Plan') {
            steps {
                sh '''
                cd Iac
                terraform plan -out=tfplan
                '''
            }
        }

        stage ('Terraform Apply') {
            steps {
                sh '''
                cd Iac
                terraform apply -auto-approve tfplan
                '''
            }
        }

        stage ('terraform destroy') {
            steps {
                sh '''
                cd Iac
                terraform destroy -auto-approve
                '''
            }
        }

        stage ('Run Test') {
            steps {
                sh '''
                cd app
                npm install
                npm test
                '''
            }
        }

        stage ('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME:$TAG -f docker/Dockerfile .'
            }
        }

        stage('Trivy Image Security Scan') {
    steps {
        script {
            sh '''
            trivy image \
            --format table \
            --output trivy-report.txt \
            $IMAGE_NAME:$TAG
            '''
        }

        archiveArtifacts artifacts: 'trivy-report.txt', fingerprint: true
    }
}

        stage ('Push Image') {
            steps {
                script {
            withDockerRegistry(
                credentialsId: 'docker-login',
                url: 'https://index.docker.io/v1/'
            ) {
                sh '''
                docker push $IMAGE_NAME:$TAG
                '''
              }
                }
            }
        }

        stage ('Deploy to Kubernetes') {
            steps {
                sh '''
                cd K8s
                sed -i "s|IMAGE_NAME|$IMAGE_NAME|g; s|TAG|${BUILD_NUMBER}|g" deployment.yml
                kubectl apply -f namespace.yml -f service.yml -f deployment.yml -f ingress.yml
                '''
            }
        }

        stage ('Validate Deployment') {
            steps {
                sh '''
                sleep 60
                kubectl get all -n node
                kubectl get ingress -n node
                '''
            }
        }

        stage ('Deploy Monitoring stack with helm') {
            steps {
                sh '''
                helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
                helm repo update
                helm install monitoring prometheus-community/kube-prometheus-stack -n monitoring --create-namespace
                '''
            }
        }
        stage ('clear workspace') {
            steps {
                cleanWs()
            }
        }
    }
}